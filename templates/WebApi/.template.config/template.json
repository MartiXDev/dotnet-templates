{
  "$schema": "http://json.schemastore.org/template",
  "author": "MartiXDev",
  "classifications": ["Web", "API", "Clean Architecture"],
  "identity": "MartiXDev.WebApiTemplate",
  "name": "MartiXDev Web API Template",
  "description": "A custom .NET 10+ / C# 14+ Web API project template built on top of MartiXDev/WebApi.",
  "shortName": "martixdev-webapi",
  "sourceName": "WebApiTemplate",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "symbols": {
    "Framework": {
      "type": "parameter",
      "description": "The target framework for the project.",
      "datatype": "choice",
      "choices": [
        {
          "choice": "net10.0",
          "description": ".NET 10"
        }
      ],
      "defaultValue": "net10.0",
      "replaces": "net10.0"
    }
  }
}
